{
  "name": "local",
  "providerType": "local-docker",
  "hostRoot": "./orbit-test-run",
  "port": 8080,
  "workerImage": "orbit-worker:local",
  "workerUser": "root",
  "manifestRoot": "/orbit/manifests",
  "isUnlocked": true,
  "useSudo": false,
  "storage": {
    "workspacesRoot": "/orbit/workspaces",
    "mirrorPath": "/orbit/main"
  },
  "mounts": [
    { "host": "./orbit-test-run", "capsule": "/orbit" },
    { "host": "~/.gemini", "capsule": "/orbit/home/.gemini", "readonly": true },
    {
      "host": "~/.config/gh",
      "capsule": "/orbit/home/.config/gh",
      "readonly": true
    },
    { "host": "/dev/shm", "capsule": "/dev/shm" }
  ],
  "bundlePath": "/orbit/bundle"
}
