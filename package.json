{
  "name": "@google/gemini-orbit-extension",
  "version": "0.0.47",
  "description": "High-performance remote missions for Gemini CLI.",
  "type": "module",
  "scripts": {
    "build": "npm run build:typecheck && npm run build:bundle",
    "build:bundle": "tsx tools/bundle.ts",
    "build:typecheck": "npm run typecheck",
    "test": "vitest run",
    "test:behavior": "vitest run behavior.test.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "sync-docs": "tsx tools/sync-docs.ts",
    "local:station": "tsx scripts/start-local-supervisor.ts",
    "local:chat:docker": "tsx scripts/dev-local-chat.ts",
    "local:chat:worktree": "tsx scripts/dev-local-worktree-chat.ts",
    "local:scorch": "tsx scripts/dev-scorch-local.ts",
    "local:scorch:images": "tsx scripts/dev-scorch-local.ts --images",
    "fleet:pulse": "node bundle/orbit-cli.js constellation --pulse",
    "fleet:shell": "node bundle/orbit-cli.js station shell",
    "fleet:attach": "node bundle/orbit-cli.js mission attach --verbose",
    "fleet:smoke": "tsx scripts/station-smoke.ts",
    "infra:liftoff": "node bundle/orbit-cli.js infra liftoff",
    "infra:splashdown": "node bundle/orbit-cli.js infra splashdown",
    "infra:gcp:prep": "node bundle/orbit-cli.js infra prepare",
    "infra:pulumi:install": "tsx scripts/ensure-pulumi.ts",
    "maint:release": "tsx tools/prepare-release.ts"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "npm run sync-docs",
      "prettier --write",
      "eslint --fix",
      "npm run build:bundle"
    ],
    "*.md": [
      "npm run sync-docs",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "author": "Matt Korwel",
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/glob": "^8.1.0",
    "@types/node": "^20.11.0",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@pulumi/gcp": "^9.17.1",
    "@pulumi/pulumi": "^3.228.0",
    "glob": "^13.0.6",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  }
}
